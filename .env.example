# Decision Mirror — environment configuration.
# Copy to `.env.local` (git-ignored) and fill in real values. NEVER commit secrets.
# Every key below is required for the corresponding feature to work; the app fails fast
# at startup if a key it needs is missing.

# --- Database ---------------------------------------------------------------
# PostgreSQL connection string. Local dev uses the docker-compose Postgres (pgvector).
# Serves relational data, pgvector long-term memory, and the LangGraph checkpointer.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/decision_mirror?schema=public"

# --- Authentication (Auth.js v5) --------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Google OAuth credentials (Google Cloud Console → Credentials → OAuth client ID).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- LLM provider (OpenAI) --------------------------------------------------
OPENAI_API_KEY=""
# Model id used by the analysis agent (a fast/cheap model is fine for the demo).
OPENAI_ANALYSIS_MODEL="gpt-5.4-mini"

# --- Embeddings (long-term agent memory) ------------------------------------
# Voyage AI is the default; OpenAI works behind the same wrapper.
AGENT_EMBEDDINGS_PROVIDER="voyage"
VOYAGE_API_KEY=""
VOYAGE_EMBEDDINGS_MODEL="voyage-3"
OPENAI_EMBEDDINGS_MODEL="text-embedding-3-small"
AGENT_MEMORY_TOP_K="3"

# --- Observability ----------------------------------------------------------
# Errors / performance (Sentry). Decision text is never sent to Sentry.
SENTRY_DSN=""
# Product / business analytics (PostHog). Decision text is never sent to PostHog.
POSTHOG_KEY=""
# Agent tracing + evals (LangSmith). May see decision content by design — keep scoped.
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="decision-analysis"
# Required only when using an org-scoped LangSmith API key.
LANGSMITH_WORKSPACE_ID=""
